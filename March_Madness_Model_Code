        "## Strength of Schedule\n",
        "\n",
        "# create first a team winrate for each team in each season\n",
        "team_wins = games_seperated.groupby(['Season','TeamID'])['Win'].mean().reset_index().rename(columns = {\"TeamID\": \"OppID\",\"Win\": \"OppWinPercentage\"})\n",
        "\n",
        "# join win percentages onto original dataset\n",
        "games_seperated = games_seperated.merge(team_wins, how = 'left', on = ['Season', 'OppID'])"
      ]
