        "## Create confusion matrices for each model\n",
        "\n",
        "# Define function\n",
        "\n",
        "def create_cm(model, X_test_N_scaled, y_test_N):\n",
        "  y_prediction = model.predict(X_test_N_scaled)\n",
        "  cm = confusion_matrix(y_test_N,y_prediction)\n",
        "\n",
        "  cm_df = pd.DataFrame(cm,index = ['Actual Losses', 'Actual Wins'],\n",
        "                    columns = ['Predicted Losses', 'Predicted Wins'])\n",
        "  return cm_df\n",
        "\n",
        "# Create for each model\n",
        "cm_A = create_cm(model_A, X_test_A_scaled, y_test_A)\n",
        "cm_B = create_cm(model_B, X_test_B_scaled,y_test_B)\n",
        "cm_C = create_cm(model_C, X_test_C_scaled, y_test_C)\n",
        "\n",
        "# Plot for each model\n",
        "sns.heatmap(cm_A, annot = True, cmap = 'Blues', fmt = 'd')\n",
        "\n",
        "plt.title('Confusion Matrix - Model A')\n",
        "plt.xlabel('Predicted Lables')\n",
        "plt.ylabel('Actual Labels')\n",
        "\n",
        "plt.show()"
      ]
