      "source": [
        "## Start with basic percentages and metrics\n",
        "\n",
        "# shooting efficiency\n",
        "games_seperated['FG_Pct'] = games_seperated['FGM']/games_seperated['FGA']\n",
        "games_seperated['Opp_FG_Pct'] = games_seperated['Opp_FGM']/games_seperated['Opp_FGA']\n",
        "games_seperated['FG_3Pct'] = games_seperated['FGM3']/games_seperated['FGA3']\n",
        "games_seperated['Opp_FG_3Pct'] = games_seperated['Opp_FGM3']/games_seperated['Opp_FGA3']\n",
        "games_seperated['FT_Pct'] = games_seperated['FTM']/games_seperated['FTA']\n",
        "games_seperated['Opp_FT_Pct'] = games_seperated['Opp_FTM']/games_seperated['Opp_FTA']\n",
        "\n",
        "# point differential\n",
        "games_seperated['PointDiff'] = games_seperated['Score'] - games_seperated['OppScore']\n",
        "\n",
        "# possessions (calculated in basketball stats as FGA + (0.44 * FTA) + TO - ORB)\n",
        "games_seperated['Possessions'] = (\n",
        "                                  games_seperated['FGA']\n",
        "                                  + (0.44 * games_seperated['FTA'])\n",
        "                                  + games_seperated['TO']\n",
        "                                  - games_seperated['OR']\n",
        "                                  )\n",
        "games_seperated['Opp_Possessions'] = (\n",
        "    games_seperated['Opp_FGA'] +\n",
        "    (0.44 * games_seperated['Opp_FTA']) +\n",
        "    games_seperated['Opp_TO'] -\n",
        "    games_seperated['Opp_OR']\n",
        ")\n",
        "games_seperated.iloc[:, -10:].head()"
      ]
