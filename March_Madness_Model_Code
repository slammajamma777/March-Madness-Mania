        "tree_model_val_preds = tree_model.predict(X_val)\n",
        "forest_model_val_preds = forest_model.predict(X_val)\n",
        "svc_model_val_preds = svc_model.predict(X_val_scaled)\n",
        "xgb_model_val_preds = xgb_model.predict(X_val)\n",
        "\n",
        "# calculate probabilites for each model (1 for the prob. that the row belongs to a winner)\n",
        "log_model_val_probas = log_model.predict_proba(X_val_scaled)[:,1]\n",
        "tree_model_val_probas = tree_model.predict_proba(X_val)[:,1]\n",
        "forest_model_val_probas = forest_model.predict_proba(X_val)[:,1]\n",
        "svc_model_val_probas = svc_model.predict_proba(X_val_scaled)[:,1]\n",
        "xgb_model_val_probas = xgb_model.predict_proba(X_val)[:,1]\n",
        "\n",
        "# create accuracy scores for each model\n",
        "log_model_accuracy = accuracy_score(y_val, log_model_val_preds)\n",
