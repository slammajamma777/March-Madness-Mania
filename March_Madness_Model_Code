        "\n",
        "for split_name, split_data in recent_splits.items():\n",
        "\n",
        "    # isolate X and y\n",
        "    X_tr, y_tr = split_data['train'][feature_columns], split_data['train']['Target']\n",
        "    X_v,  y_v  = split_data['val'][feature_columns],   split_data['val']['Target']\n",
        "    X_te, y_te = split_data['test'][feature_columns],  split_data['test']['Target']\n",
        "\n",
        "    # fit scaler on training data only\n",
        "    split_scaler = StandardScaler()\n",
        "    X_tr_scaled  = split_scaler.fit_transform(X_tr)\n",
        "    X_v_scaled   = split_scaler.transform(X_v)\n",
        "    X_te_scaled  = split_scaler.transform(X_te)\n",
        "\n",
        "    for model_name, (model, scaled) in models_config.items():\n",
        "\n",
        "        # select correct input format\n",
        "        X_train_in = X_tr_scaled if scaled else X_tr\n",
        "        X_val_in   = X_v_scaled  if scaled else X_v\n",
        "\n",
        "        # fit model\n",
        "        model.fit(X_train_in, y_tr)\n",
        "\n",
        "        # predict\n",
        "        val_preds = model.predict(X_val_in)\n",
        "        val_probs = model.predict_proba(X_val_in)[:,1]\n",
        "\n",
        "        # cross validation\n",
        "        cv_score = cross_val_score(model, X_train_in, y_tr, cv=5).mean()\n",
        "\n",
        "        recent_split_results.append({\n",
        "            'Iteration':      split_name,\n",
        "            'Model':          model_name,\n",
        "            'Train Seasons':  f\"{split_data['train']['Season'].min()}—{split_data['train']['Season'].max()}\",\n",
        "            'Train Size':     len(X_tr),\n",
        "            'Val Size':       len(X_v),\n",
        "            'Accuracy Score': round(accuracy_score(y_v, val_preds), 4),\n",
        "            'MSE':            round(mean_squared_error(y_v, val_probs), 4),\n",
        "            'CV Score':       round(cv_score, 4)\n",
        "        })\n",
        "\n",
        "## Compile results\n",
        "recent_results_df = pd.DataFrame(recent_split_results)\n",
        "\n",
        "## Display results per iteration\n",
        "for split_name in recent_splits.keys():\n",
        "    print(f'\\n{split_name}')\n",
        "    print('=' * 60)\n",
        "    display(recent_results_df[recent_results_df['Iteration'] == split_name]\n",
        "            [['Model','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "            .sort_values('Accuracy Score', ascending=False)\n",
        "            .reset_index(drop=True))\n",
        "\n",
        "## Summary — best model per iteration\n",
        "print('\\nBest Model Per Iteration — Recent Splits')\n",
        "print('=' * 60)\n",
        "display(recent_results_df.loc[recent_results_df.groupby('Iteration')['Accuracy Score'].idxmax()]\n",
        "        [['Iteration','Model','Train Seasons','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "        .reset_index(drop=True))\n",
        "\n",
        "## Combined summary across all iterations including earlier ones\n",
        "print('\\nFull Summary — All Iterations')\n",
        "print('=' * 60)\n",
        "all_results_combined = pd.concat([split_results_df, recent_results_df])\n",
        "display(all_results_combined.loc[all_results_combined.groupby('Iteration')['Accuracy Score'].idxmax()]\n",
        "        [['Iteration','Model','Train Seasons','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "        .sort_values('Accuracy Score', ascending=False)\n",
        "        .reset_index(drop=True))"
      ]
    },
