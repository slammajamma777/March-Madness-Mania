        "## Split Iterations — All Four Configurations\n",
        "## Using GridSearch best estimators throughout\n",
        "\n",
        "splits = {\n",
        "    'Iteration 3 — 2008-2018 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2008) & (m_matchups['Season'] <= 2018)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] > 2018) & (m_matchups['Season'] <= 2022)],\n",
        "        'test':  m_matchups[m_matchups['Season'] >= 2023]\n",
        "    },\n",
        "    'Iteration 4 — 2013-2018 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2013) & (m_matchups['Season'] <= 2018)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] > 2018) & (m_matchups['Season'] <= 2022)],\n",
        "        'test':  m_matchups[m_matchups['Season'] >= 2023]\n",
        "    },\n",
        "    'Iteration 5 — 2003-2021 Train': {\n",
        "        'train': m_matchups[m_matchups['Season'] <= 2021],\n",
        "        'val':   m_matchups[m_matchups['Season'] == 2022],\n",
        "        'test':  m_matchups[m_matchups['Season'] >= 2023]\n",
        "    },\n",
        "    'Iteration 6 — 2013-2021 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2013) & (m_matchups['Season'] <= 2021)],\n",
        "        'val':   m_matchups[m_matchups['Season'] == 2022],\n",
        "        'test':  m_matchups[m_matchups['Season'] >= 2023]\n",
        "    }\n",
        "}\n",
        "\n",
        "models_config = {\n",
        "    'Logistic Regression': (log_grid.best_estimator_, True),\n",
        "    'Decision Tree':        (tree_grid.best_estimator_, False),\n",
        "    'Random Forest':        (forest_grid.best_estimator_, False),\n",
        "    'SVM':                  (svc_grid.best_estimator_, True),\n",
        "    'XGBoost':              (xgb_grid.best_estimator_, False)\n",
        "}\n",
        "\n",
        "## Store all iteration results\n",
        "all_split_results = []\n",
        "\n",
        "for split_name, split_data in splits.items():\n",
        "\n",
        "    # isolate X and y\n",
        "    X_tr, y_tr = split_data['train'][feature_columns], split_data['train']['Target']\n",
        "    X_v,  y_v  = split_data['val'][feature_columns],   split_data['val']['Target']\n",
        "    X_te, y_te = split_data['test'][feature_columns],  split_data['test']['Target']\n",
        "\n",
        "    # fit scaler on training data only\n",
        "    split_scaler    = StandardScaler()\n",
        "    X_tr_scaled     = split_scaler.fit_transform(X_tr)\n",
        "    X_v_scaled      = split_scaler.transform(X_v)\n",
        "    X_te_scaled     = split_scaler.transform(X_te)\n",
        "\n",
        "    for model_name, (model, scaled) in models_config.items():\n",
        "\n",
        "        # select correct input format\n",
        "        X_train_in = X_tr_scaled if scaled else X_tr\n",
        "        X_val_in   = X_v_scaled  if scaled else X_v\n",
        "\n",
        "        # fit model\n",
        "        model.fit(X_train_in, y_tr)\n",
        "\n",
        "        # predict\n",
        "        val_preds = model.predict(X_val_in)\n",
        "        val_probs = model.predict_proba(X_val_in)[:,1]\n",
        "\n",
        "        # cross validation\n",
        "        cv_score = cross_val_score(model, X_train_in, y_tr, cv=10).mean()\n",
        "\n",
        "        all_split_results.append({\n",
        "            'Iteration':      split_name,\n",
        "            'Model':          model_name,\n",
        "            'Train Seasons':  f\"{split_data['train']['Season'].min()}—{split_data['train']['Season'].max()}\",\n",
        "            'Train Size':     len(X_tr),\n",
        "            'Val Size':       len(X_v),\n",
        "            'Accuracy Score': round(accuracy_score(y_v, val_preds), 4),\n",
        "            'MSE':            round(mean_squared_error(y_v, val_probs), 4),\n",
        "            'CV Score':       round(cv_score, 4)\n",
        "        })\n",
        "\n",
        "## Compile results\n",
        "split_results_df = pd.DataFrame(all_split_results)\n",
        "\n",
        "## Display results per iteration\n",
