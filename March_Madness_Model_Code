      "source": [
        "## Dean Oliver's 4 Factors\n",
        "\n",
        "# eFG - Effective Field Goal Percentage (FGM + 0.5 * 3PM)/FGA\n",
        "games_seperated['eFG'] = (games_seperated['FGM'] + 0.5 * games_seperated['FGM3'])/games_seperated['FGA']\n",
        "games_seperated['Opp_eFG'] = (games_seperated['Opp_FGM'] + 0.5 * games_seperated['Opp_FGM3'])/games_seperated['Opp_FGA']\n",
        "\n",
        "# Turnover Percentage (100 * TO)/Possessions\n",
        "games_seperated['TO_Pct'] = (100 * games_seperated['TO']) / (\n",
        "    games_seperated['FGA'] + 0.44 * games_seperated['FTA'] + games_seperated['TO'])\n",
        "games_seperated['Opp_TO_Pct'] = (100 * games_seperated['Opp_TO']) / (\n",
        "    games_seperated['Opp_FGA'] + 0.44 * games_seperated['Opp_FTA'] + games_seperated['Opp_TO'])\n",
        "\n",
        "# Offensive/Defensive Rebound Percentages\n",
        "games_seperated['OR_Pct'] = (100 * (games_seperated['OR']) * (40/5))/(40 * (games_seperated['OR'] + games_seperated['Opp_DR']))\n",
        "games_seperated['DR_Pct'] = (100 * (games_seperated['DR']) * (40/5))/(40 * (games_seperated['DR'] + games_seperated['Opp_OR']))\n",
        "games_seperated['Opp_OR_Pct'] = (100 * (games_seperated['Opp_OR']) * (40/5))/(40 * (games_seperated['Opp_OR'] + games_seperated['DR']))\n",
        "games_seperated['Opp_DR_Pct'] = (100 * (games_seperated['Opp_DR']) * (40/5))/(40 * (games_seperated['Opp_DR'] + games_seperated['OR']))\n",
        "\n",
        "# Free Throw Factor - FT/FGA\n",
        "games_seperated['FT_Factor'] = games_seperated['FTM']/ games_seperated['FGA']\n",
        "games_seperated['Opp_FT_Factor'] = games_seperated['Opp_FTM']/games_seperated['Opp_FGA']\n",
        "\n",
        "games_seperated.iloc[:, -10:].head()"
      ]
    },
