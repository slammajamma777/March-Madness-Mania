        "feature_corrs = m_matchups.corrwith(m_matchups_train['Target']).drop(['Season','TeamA','TeamB','Target']).sort_values(ascending = False)\n",
        "feature_corrs_df = feature_corrs.to_frame(name='Correlation with Target')\n",
        "\n",
        "# find correlations that meet criteria of being greater than the absolute value of 0.1\n",
        "corr_important = feature_corrs_df[abs(feature_corrs_df['Correlation with Target']) >= 0.1].transpose()\n",
        "\n",
        "# isolate list of columns\n",
        "features_sign = corr_important.columns.to_list()\n",
        "\n",
        "# create models and run\n",
        "corr_feature_results = []\n",
        "\n",
        "for config_name, config_data in feature_configs.items():\n",
        "\n",
        "    # isolate X and y using correlation selected features\n",
        "    X_tr, y_tr = config_data['train'][features_sign], config_data['train']['Target']\n",
        "    X_v,  y_v  = config_data['val'][features_sign],   config_data['val']['Target']\n",
        "    X_te, y_te = config_data['test'][features_sign],  config_data['test']['Target']\n",
        "\n",
        "    # fit scaler on training data only\n",
        "    config_scaler = StandardScaler()\n",
        "    X_tr_scaled   = config_scaler.fit_transform(X_tr)\n",
        "    X_v_scaled    = config_scaler.transform(X_v)\n",
        "    X_te_scaled   = config_scaler.transform(X_te)\n",
        "\n",
        "    for model_name, (model, scaled) in {\n",
        "        'Logistic Regression': (clone(log_grid.best_estimator_), True),\n",
        "        'Decision Tree':        (clone(tree_grid.best_estimator_), False),\n",
        "        'Random Forest':        (clone(forest_grid.best_estimator_), False),\n",
        "        'SVM':                  (clone(svc_grid.best_estimator_), True),\n",
        "        'XGBoost':              (clone(xgb_grid.best_estimator_), False)\n",
        "    }.items():\n",
        "\n",
        "        # select correct input format\n",
        "        X_train_in = X_tr_scaled if scaled else X_tr\n",
        "        X_val_in   = X_v_scaled  if scaled else X_v\n",
        "\n",
        "        # fit model\n",
        "        model.fit(X_train_in, y_tr)\n",
        "\n",
        "        # predict\n",
        "        val_preds = model.predict(X_val_in)\n",
        "        val_probs = model.predict_proba(X_val_in)[:,1]\n",
        "\n",
        "        # cross validation\n",
        "        cv_folds = 5 if len(X_tr) < 300 else 10\n",
        "        cv_score = cross_val_score(model, X_train_in, y_tr, cv=cv_folds).mean()\n",
        "\n",
        "        corr_feature_results.append({\n",
        "            'Config':         config_name,\n",
        "            'Model':          model_name,\n",
        "            'Feature Set':    f'Correlation Threshold >= 0.1 ({len(features_sign)} features)',\n",
        "            'Train Size':     len(X_tr),\n",
        "            'Val Size':       len(X_v),\n",
        "            'Accuracy Score': round(accuracy_score(y_v, val_preds), 4),\n",
        "            'MSE':            round(mean_squared_error(y_v, val_probs), 4),\n",
        "            'CV Score':       round(cv_score, 4)\n",
        "        })\n",
        "\n",
        "## Compile results\n",
        "corr_feature_results_df = pd.DataFrame(corr_feature_results)\n",
        "\n",
        "## Display results per config\n",
        "for config_name in feature_configs.keys():\n",
        "    print(f'\\n{config_name} — Correlation Threshold Features')\n",
        "    print('=' * 60)\n",
        "    display(corr_feature_results_df[corr_feature_results_df['Config'] == config_name]\n",
        "            [['Model','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "            .sort_values('Accuracy Score', ascending=False)\n",
        "            .reset_index(drop=True))\n",
        "\n",
        "## Summary — best model per config\n",
        "print('\\nBest Model Per Config — Correlation Threshold Features')\n",
        "print('=' * 60)\n",
        "display(corr_feature_results_df.loc[corr_feature_results_df.groupby('Config')['Accuracy Score'].idxmax()]\n",
        "        [['Config','Model','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "        .sort_values('Accuracy Score', ascending=False)\n",
        "        .reset_index(drop=True))\n",
        "\n",
        "## Combined comparison across all three feature sets\n",
        "print('\\nFull Feature Set Comparison Across All Configs')\n",
        "print('=' * 60)\n",
        "combined_feature_df = pd.concat([feature_results_df, corr_feature_results_df])\n",
        "display(combined_feature_df.loc[combined_feature_df.groupby(['Config','Feature Set'])['Accuracy Score'].idxmax()]\n",
        "        [['Config','Feature Set','Model','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "        .sort_values(['Config','Accuracy Score'], ascending=[True, False])\n",
        "        .reset_index(drop=True))"
      ]
    },
