        "## Scoring Trends across seasons\n",
        "\n",
        "# set variable list of scoring stats\n",
        "d_scoring_stats = m_regular_detailed.columns.drop(['Season', 'DayNum', 'WTeamID', 'LTeamID','WLoc'])\n",
        "\n",
        "# group and aggregate stats by season\n",
        "stats_by_season = m_regular_detailed.groupby('Season')[d_scoring_stats].agg(['mean'])\n",
        "display(stats_by_season.head())\n",
        "\n",
        "## Creating a dictionary/dataframe for the difference in stats between 2003 and 2026 to identify potential flaggers for change through years\n",
        "\n",
        "stats_difference_dict = {}\n",
        "\n",
        "for column in stats_by_season.columns:\n",
        "  stats_difference_dict[column] = [stats_by_season.loc[2026,:][column] - stats_by_season.loc[2003,:][column]]\n",
        "\n",
        "# put into dataframe for pandas evaluation\n",
        "stats_difference_df = pd.DataFrame(stats_difference_dict)\n",
        "stats_difference_df = stats_difference_df.transpose().sort_values(by = 0, ascending = False)\n",
        "\n",
        "# sort by top 5 most positively changing metrics and top 5 most negatively changing metrics\n",
        "stats_by_season_top_5 = stats_difference_df.head()\n",
        "stats_by_season_low_5 = stats_difference_df.tail().sort_values(by = 0)\n",
        "\n",
        "display(stats_by_season_top_5, stats_by_season_low_5)"
      ]
