        "## 2026 Prediction Pipeline — Men's Submission\n",
        "\n",
        "## Step 1 — Isolate 2026 aggregated stats from m_agg\n",
        "m_agg_2026 = m_agg[m_agg['Season'] == 2026].copy()\n",
        "print('2026 teams available for prediction:', m_agg_2026.shape[0])\n",
        "\n",
        "## Step 2 — Join Team A and Team B stats onto submission file\n",
        "# join Team A stats\n",
        "submission_features = submission.merge(\n",
        "    m_agg_2026,\n",
        "    left_on='TeamA',\n",
        "    right_on='TeamID',\n",
        "    how='left'\n",
        ").drop(['TeamID', 'Season_y'], axis=1).rename(columns={'Season_x': 'Season'})\n",
        "\n",
        "# join Team B stats\n",
        "submission_features = submission_features.merge(\n",
        "    m_agg_2026,\n",
        "    left_on='TeamB',\n",
        "    right_on='TeamID',\n",
        "    how='left',\n",
        "    suffixes=('_A', '_B')\n",
        ").drop('TeamID', axis=1)\n",
        "\n",
        "print('Submission features shape:', submission_features.shape)\n",
        "\n",
        "## Step 3 — Compute differentials using features_sign\n",
        "feature_base_cols = [c.replace('_diff', '') for c in features_sign]\n",
        "\n",
        "for col in feature_base_cols:\n",
        "    submission_features[f'{col}_diff'] = (\n",
        "        submission_features[f'{col}_A'] -\n",
        "        submission_features[f'{col}_B']\n",
        "    )\n",
        "\n",
        "## Step 4 — Isolate differential feature columns for prediction\n",
        "X_2026_full = submission_features[features_sign]\n",
        "print('Full feature matrix shape:', X_2026_full.shape)\n",
        "\n",
        "## Step 4.5 — Filter to men's teams only by dropping rows with nulls\n",
        "## Women's team IDs are in the 3000s range and won't have stats in m_agg\n",
        "## which was built from men's data only — their rows will have null features\n",
        "X_2026_mens = submission_features.dropna(subset=features_sign).copy()\n",
        "\n",
        "print('\\nTotal submission rows:     ', submission_features.shape[0])\n",
        "print('Rows after dropping nulls: ', X_2026_mens.shape[0])\n",
        "print('Rows dropped (womens):     ', submission_features.shape[0] - X_2026_mens.shape[0])\n",
        "\n",
        "# isolate feature matrix for men's only\n",
        "X_2026 = X_2026_mens[features_sign]\n",
        "print('Men\\'s prediction feature matrix shape:', X_2026.shape)\n",
        "print('Null counts in feature matrix:', X_2026.isnull().sum().sum())\n",
        "\n",
        "## Step 5 — Scale using each model's scaler and generate predictions\n",
        "\n",
        "# Model B predictions\n",
        "X_2026_scaled_B = scaler_B.transform(X_2026)\n",
        "probs_B         = model_B.predict_proba(X_2026_scaled_B)[:,1]\n",
