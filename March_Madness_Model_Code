      "source": [
        "## Join aggregated stats onto each consolidated tournament game\n",
        "\n",
        "# join Team A and Team B in replace of TeamIDs\n",
        "m_matchups = m_tourney_model.merge(m_agg, left_on = ['Season','TeamA'], right_on = ['Season','TeamID'], how = 'left').drop('TeamID', axis = 1)\n",
        "m_matchups = m_matchups.merge(m_agg, left_on = ['Season','TeamB'], right_on = ['Season','TeamID'], how = 'left',suffixes = ('_A','_B')).drop('TeamID', axis = 1)\n",
        "\n",
        "# create differentials for each feature\n",
        "feature_cols = [c for c in m_agg.columns if c not in ['Season','TeamID']]\n",
        "\n",
        "for col in feature_cols:\n",
        "  m_matchups[f'{col}_diff'] = m_matchups[f'{col}_A'] - m_matchups[f'{col}_B'] # iterates through each column in m_agg and creates a new column in matchups using the column injected to create a differential\n",
        "\n",
        "# drop irrelevant columns (not diffential and season, TeamA and TeamB)\n",
        "diff_cols = [f'{c}_diff' for c in feature_cols]\n",
        "m_matchups = m_matchups[['Season','TeamA','TeamB'] + diff_cols + ['Target']]"
      ]
    },
