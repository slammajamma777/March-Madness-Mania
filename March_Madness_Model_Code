      "source": [
        "## Aggregate Game Level Data to Season Level Data\n",
        "\n",
        "# Create a list of columns to use for prediction\n",
        "complete_features = ['Score','OppScore','NumOT',\n",
        "       'FGM', 'FGA', 'FGM3', 'FGA3', 'FTM', 'FTA', 'OR', 'DR', 'Ast', 'TO',\n",
        "       'Stl', 'Blk', 'PF', 'Opp_FGM', 'Opp_FGA', 'Opp_FGM3', 'Opp_FGA3',\n",
        "       'Opp_FTM', 'Opp_FTA', 'Opp_OR', 'Opp_DR', 'Opp_Ast', 'Opp_TO',\n",
        "       'Opp_Stl', 'Opp_Blk', 'Opp_PF', 'Win', 'FG_Pct', 'Opp_FG_Pct',\n",
        "       'FG_3Pct', 'Opp_FG_3Pct', 'FT_Pct', 'Opp_FT_Pct', 'PointDiff',\n",
        "       'Possessions', 'Opp_Possessions', 'eFG', 'Opp_eFG', 'TO_Pct',\n",
        "       'Opp_TO_Pct', 'OR_Pct', 'DR_Pct', 'Opp_OR_Pct', 'Opp_DR_Pct',\n",
        "       'FT_Factor', 'Opp_FT_Factor', 'Off_Eff', 'Opp_Off_Eff', 'Def_Eff',\n",
        "       'Opp_Def_Eff', 'Net_Eff', 'Opp_Net_Eff', 'OppWinPercentage']\n",
        "\n",
        "# aggregate by season and team with the mean\n",
        "agg_mean = games_seperated.groupby(['Season','TeamID'])[complete_features].mean().reset_index()\n",
        "\n",
        "# create standard deviation features for columns that make sense\n",
        "std_features = ['PointDiff','Score','OppScore','Net_Eff','Off_Eff','Def_Eff','FG_Pct','FG_3Pct','eFG','TO_Pct']\n",
        "agg_std = games_seperated.groupby(['Season','TeamID'])[std_features].std().reset_index()\n",
        "\n",
        "# rename to diffentiate between mean and std\n",
        "agg_std = agg_std.rename(columns={\n",
        "    'PointDiff': 'Std_PointDiff',\n",
        "    'Score': 'Std_Score',\n",
        "    'OppScore': 'Std_OppScore',\n",
        "    'Net_Eff': 'Std_Net_Eff',\n",
        "    'Off_Eff': 'Std_Off_Eff',\n",
        "    'Def_Eff': 'Std_Def_Eff',\n",
        "    'FG_Pct': 'Std_FG_Pct',\n",
        "    'FG_3Pct': 'Std_FG_3Pct',\n",
        "    'eFG': 'Std_eFG',\n",
        "    'TO_Pct': 'Std_TO_Pct'\n",
        "})\n",
        "\n",
        "# join mean and std aggregated columns onto each other\n",
        "m_agg = pd.merge(left = agg_mean,right = agg_std,how = 'left',on = ['Season','TeamID'])\n",
        "m_agg.head()"
      ]
