      "source": [
        "# flag games that are conference vs conference\n",
        "games_seperated['In_Conference_Game'] = (games_seperated['Conference'] == games_seperated['Opp_Conference']).astype(int)\n",
        "\n",
        "# calculate win percentages for teams out of conference vs in conference\n",
        "in_conference = games_seperated[games_seperated['In_Conference_Game'] == 1].groupby(['Season','TeamID'])['Win'].mean().reset_index().rename(columns = {'Win': 'In_Conference_Win_Percentage'})\n",
        "out_conference = games_seperated[games_seperated['In_Conference_Game'] == 0].groupby(['Season','TeamID'])['Win'].mean().reset_index().rename(columns = {'Win': 'Out_Conference_Win_Percentage'})\n",
        "\n",
        "# merge together for one datatable\n",
        "conference_vs_outconference = in_conference.merge(out_conference, on = ['Season','TeamID'], how = 'outer')\n",
        "conference_vs_outconference"
      ]
    },
