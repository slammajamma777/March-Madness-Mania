      "source": [
        "## Create tournament-ready rows that can be joined onto with the aggregated data\n",
        "\n",
        "# Filter m_tourney_results from 2003 onwards\n",
        "m_tourney_model = m_tourney_results.loc[m_tourney_results['Season'] >= 2003].copy()\n",
        "print(m_tourney_model.sample(5))\n",
        "\n",
        "# Drop irrelevant columns and only keep Season, WTeamID and LTeamID and the scores**\n",
        "m_tourney_model.drop(['DayNum','WLoc','NumOT'], axis = 1, inplace = True)\n",
        "print('--' *30, '\\n', m_tourney_model.sample(5))\n",
        "\n",
        "# Set team A as lower ID and team B as higher ID\n",
        "m_tourney_model['TeamA'] = m_tourney_model[['WTeamID','LTeamID']].min(axis = 1)\n",
        "m_tourney_model['TeamB'] = m_tourney_model[['WTeamID','LTeamID']].max(axis = 1)\n",
        "print('--' * 20, '\\n',m_tourney_model.sample(5))\n",
        "\n",
        "# target = 1 if Team A won and 0 if Team B won\n",
        "m_tourney_model['Target'] = (m_tourney_model['WTeamID'] == m_tourney_model['TeamA']).astype(int)\n",
        "print('--' * 20, '\\n',m_tourney_model.sample(5))\n",
        "\n",
        "# drop WTeamId, WScore, LTeamID,LScore now that we have derived the target\n",
        "m_tourney_model.drop(['WTeamID','WScore','LTeamID','LScore'], axis = 1, inplace = True)\n",
        "print('--' * 20, '\\n',m_tourney_model.sample(5))\n",
        "\n",
        "\n",
        "\n",
        "\n"
      ]
