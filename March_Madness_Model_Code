        "## Split Iterations — 10 Configurations, Fixed Val and Test\n",
        "\n",
        "splits_all = {\n",
        "    'Iteration 1 — 2003-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2003) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 2 — 2008-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2008) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 3 — 2013-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2013) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 4 — 2015-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2015) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 5 — 2016-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2016) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 6 — 2018-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2018) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 7 — 2019-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2019) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 8 — 2003-2022 Train (No 2020)': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2003) & (m_matchups['Season'] <= 2022) &\n",
        "                            (m_matchups['Season'] != 2020)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 9 — 2013-2022 Train (No 2020)': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2013) & (m_matchups['Season'] <= 2022) &\n",
        "                            (m_matchups['Season'] != 2020)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Iteration 10 — 2016-2022 Train (No 2020)': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2016) & (m_matchups['Season'] <= 2022) &\n",
        "                            (m_matchups['Season'] != 2020)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    }\n",
        "}\n",
        "\n",
        "## Store all results\n",
        "all_results = []\n",
        "\n",
        "for split_name, split_data in splits_all.items():\n",
        "\n",
        "    # fresh clones at the start of every iteration\n",
        "    from sklearn.base import clone\n",
        "    models_config = {\n",
        "        'Logistic Regression': (clone(log_grid.best_estimator_), True),\n",
        "        'Decision Tree':        (clone(tree_grid.best_estimator_), False),\n",
        "        'Random Forest':        (clone(forest_grid.best_estimator_), False),\n",
        "        'SVM':                  (clone(svc_grid.best_estimator_), True),\n",
        "        'XGBoost':              (clone(xgb_grid.best_estimator_), False)\n",
        "    }\n",
        "\n",
        "    # then all the data splitting, fitting, predicting below\n",
        "    X_tr, y_tr = split_data['train'][feature_columns], split_data['train']['Target']\n",
        "    # ...\n",
        "    # isolate X and y\n",
        "    X_tr, y_tr = split_data['train'][feature_columns], split_data['train']['Target']\n",
        "    X_v,  y_v  = split_data['val'][feature_columns],   split_data['val']['Target']\n",
        "    X_te, y_te = split_data['test'][feature_columns],  split_data['test']['Target']\n",
        "\n",
        "    # fit scaler on training data only\n",
        "    split_scaler = StandardScaler()\n",
        "    X_tr_scaled  = split_scaler.fit_transform(X_tr)\n",
        "    X_v_scaled   = split_scaler.transform(X_v)\n",
        "    X_te_scaled  = split_scaler.transform(X_te)\n",
        "\n",
        "    for model_name, (model, scaled) in models_config.items():\n",
        "\n",
        "        # select correct input format\n",
        "        X_train_in = X_tr_scaled if scaled else X_tr\n",
        "        X_val_in   = X_v_scaled  if scaled else X_v\n",
        "\n",
        "        # fit model\n",
        "        model.fit(X_train_in, y_tr)\n",
        "\n",
        "        # predict\n",
        "        val_preds = model.predict(X_val_in)\n",
        "        val_probs = model.predict_proba(X_val_in)[:,1]\n",
        "\n",
        "        # cross validation\n",
        "        cv_folds = 5 if len(X_tr) < 300 else 10\n",
        "        cv_score = cross_val_score(model, X_train_in, y_tr, cv=cv_folds).mean()\n",
        "\n",
        "        all_results.append({\n",
        "            'Iteration':      split_name,\n",
        "            'Model':          model_name,\n",
        "            'Train Seasons':  f\"{split_data['train']['Season'].min()}—{split_data['train']['Season'].max()}\",\n",
        "            'Train Size':     len(X_tr),\n",
        "            'Val Size':       len(X_v),\n",
        "            'Accuracy Score': round(accuracy_score(y_v, val_preds), 4),\n",
        "            'MSE':            round(mean_squared_error(y_v, val_probs), 4),\n",
        "            'CV Score':       round(cv_score, 4)\n",
        "        })\n",
        "\n",
        "## Compile results\n",
        "all_results_df = pd.DataFrame(all_results)\n",
        "\n",
        "## Display results per iteration\n",
        "for split_name in splits_all.keys():\n",
        "    print(f'\\n{split_name}')\n",
        "    print('=' * 60)\n",
        "    display(all_results_df[all_results_df['Iteration'] == split_name]\n",
        "            [['Model','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "            .sort_values('Accuracy Score', ascending=False)\n",
        "            .reset_index(drop=True))\n",
        "\n",
        "## Summary — best model per iteration\n",
        "print('\\nBest Model Per Iteration')\n",
        "print('=' * 60)\n",
        "display(all_results_df.loc[all_results_df.groupby('Iteration')['Accuracy Score'].idxmax()]\n",
        "        [['Iteration','Model','Train Seasons','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "        .sort_values('Accuracy Score', ascending=False)\n",
        "        .reset_index(drop=True))"
      ]
    },
