      "source": [
        "## Create a table that only keeps relevant columns\n",
        "\n",
        "# find reduced features (thank you Claude)\n",
        "reduced_features = [c for c in feature_columns if c not in [\n",
        "    # raw box score counts\n",
        "    'FGM_diff', 'FGA_diff',\n",
        "    'FGM3_diff', 'FGA3_diff',\n",
        "    'FTM_diff', 'FTA_diff',\n",
        "    'OR_diff', 'DR_diff',\n",
        "    'Ast_diff', 'TO_diff',\n",
        "    'Stl_diff', 'Blk_diff', 'PF_diff',\n",
        "    # opponent raw box score counts\n",
        "    'Opp_FGM_diff', 'Opp_FGA_diff',\n",
        "    'Opp_FGM3_diff', 'Opp_FGA3_diff',\n",
        "    'Opp_FTM_diff', 'Opp_FTA_diff',\n",
        "    'Opp_OR_diff', 'Opp_DR_diff',\n",
        "    'Opp_Ast_diff', 'Opp_TO_diff',\n",
        "    'Opp_Stl_diff', 'Opp_Blk_diff', 'Opp_PF_diff',\n",
        "    # redundant efficiency metrics\n",
        "    'Opp_Off_Eff_diff', 'Opp_Def_Eff_diff', 'Opp_Net_Eff_diff',\n",
        "    # redundant score/possession metrics\n",
        "    'Score_diff', 'OppScore_diff',\n",
        "    'NumOT_diff',\n",
        "    'Possessions_diff', 'Opp_Possessions_diff',\n",
        "]]\n",
        "\n",
        "# instantiate all 3 models with different splits\n",
        "feature_configs = {\n",
        "    'Config A — 2013-2018 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2013) & (m_matchups['Season'] <= 2018)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] > 2018) & (m_matchups['Season'] <= 2022)],\n",
        "        'test':  m_matchups[m_matchups['Season'] >= 2023]\n",
        "    },\n",
        "    'Config B — 2016-2022 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2016) & (m_matchups['Season'] <= 2022)],\n",
        "        'val':   m_matchups[(m_matchups['Season'] >= 2023) & (m_matchups['Season'] <= 2024)],\n",
        "        'test':  m_matchups[m_matchups['Season'] == 2025]\n",
        "    },\n",
        "    'Config C — 2013-2021 Train': {\n",
        "        'train': m_matchups[(m_matchups['Season'] >= 2013) & (m_matchups['Season'] <= 2021)],\n",
        "        'val':   m_matchups[m_matchups['Season'] == 2022],\n",
        "        'test':  m_matchups[m_matchups['Season'] >= 2023]\n",
        "    }\n",
        "}\n",
        "\n",
        "#\n",
        "feature_results = []\n",
        "\n",
        "for config_name, config_data in feature_configs.items():\n",
        "\n",
        "    # isolate X and y using reduced features\n",
        "    X_tr, y_tr = config_data['train'][reduced_features], config_data['train']['Target']\n",
        "    X_v,  y_v  = config_data['val'][reduced_features],   config_data['val']['Target']\n",
        "    X_te, y_te = config_data['test'][reduced_features],  config_data['test']['Target']\n",
        "\n",
        "    # fit scaler on training data only\n",
        "    config_scaler = StandardScaler()\n",
        "    X_tr_scaled   = config_scaler.fit_transform(X_tr)\n",
        "    X_v_scaled    = config_scaler.transform(X_v)\n",
        "    X_te_scaled   = config_scaler.transform(X_te)\n",
        "\n",
        "    for model_name, (model, scaled) in {\n",
        "        'Logistic Regression': (clone(log_grid.best_estimator_), True),\n",
        "        'Decision Tree':        (clone(tree_grid.best_estimator_), False),\n",
        "        'Random Forest':        (clone(forest_grid.best_estimator_), False),\n",
        "        'SVM':                  (clone(svc_grid.best_estimator_), True),\n",
        "        'XGBoost':              (clone(xgb_grid.best_estimator_), False)\n",
        "    }.items():\n",
        "\n",
        "        # select correct input format\n",
        "        X_train_in = X_tr_scaled if scaled else X_tr\n",
        "        X_val_in   = X_v_scaled  if scaled else X_v\n",
        "\n",
        "        # fit model\n",
        "        model.fit(X_train_in, y_tr)\n",
        "\n",
        "        # predict\n",
        "        val_preds = model.predict(X_val_in)\n",
        "        val_probs = model.predict_proba(X_val_in)[:,1]\n",
        "\n",
        "        # cross validation\n",
        "        cv_folds = 5 if len(X_tr) < 300 else 10\n",
        "        cv_score = cross_val_score(model, X_train_in, y_tr, cv=cv_folds).mean()\n",
        "\n",
        "        feature_results.append({\n",
        "            'Config':         config_name,\n",
        "            'Model':          model_name,\n",
        "            'Feature Set':    'Reduced — No Raw Box Scores',\n",
        "            'Train Size':     len(X_tr),\n",
        "            'Val Size':       len(X_v),\n",
        "            'Accuracy Score': round(accuracy_score(y_v, val_preds), 4),\n",
        "            'MSE':            round(mean_squared_error(y_v, val_probs), 4),\n",
        "            'CV Score':       round(cv_score, 4)\n",
        "        })\n",
        "\n",
        "## Compile results\n",
        "feature_results_df = pd.DataFrame(feature_results)\n",
        "\n",
        "## Display results per config\n",
        "for config_name in feature_configs.keys():\n",
        "    print(f'\\n{config_name} — Reduced Features')\n",
        "    print('=' * 60)\n",
        "    display(feature_results_df[feature_results_df['Config'] == config_name]\n",
        "            [['Model','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "            .sort_values('Accuracy Score', ascending=False)\n",
        "            .reset_index(drop=True))\n",
        "\n",
        "## Summary — best model per config\n",
        "print('\\nBest Model Per Config — Reduced Features')\n",
        "print('=' * 60)\n",
        "display(feature_results_df.loc[feature_results_df.groupby('Config')['Accuracy Score'].idxmax()]\n",
        "        [['Config','Model','Train Size','Val Size','Accuracy Score','MSE','CV Score']]\n",
        "        .sort_values('Accuracy Score', ascending=False)\n",
        "        .reset_index(drop=True))"
      ]
    },
