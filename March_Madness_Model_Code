      "source": [
        "## Iteration 2 — GridSearchCV Tuned Models\n",
        "\n",
        "# extract best estimators from grids\n",
        "log_model2   = log_grid.best_estimator_\n",
        "tree_model2  = tree_grid.best_estimator_\n",
        "forest_model2 = forest_grid.best_estimator_\n",
        "svc_model2   = svc_grid.best_estimator_\n",
        "xgb_model2   = xgb_grid.best_estimator_\n",
        "\n",
        "# predict validation scores\n",
        "log_model2_val_preds    = log_model2.predict(X_val_scaled)\n",
        "tree_model2_val_preds   = tree_model2.predict(X_val)\n",
        "forest_model2_val_preds = forest_model2.predict(X_val)\n",
        "svc_model2_val_preds    = svc_model2.predict(X_val_scaled)\n",
        "xgb_model2_val_preds    = xgb_model2.predict(X_val)\n",
        "\n",
        "# calculate probabilities for each model\n",
        "log_model2_val_probas    = log_model2.predict_proba(X_val_scaled)[:,1]\n",
        "tree_model2_val_probas   = tree_model2.predict_proba(X_val)[:,1]\n",
        "forest_model2_val_probas = forest_model2.predict_proba(X_val)[:,1]\n",
        "svc_model2_val_probas    = svc_model2.predict_proba(X_val_scaled)[:,1]\n",
        "xgb_model2_val_probas    = xgb_model2.predict_proba(X_val)[:,1]\n",
        "\n",
        "# create accuracy scores for each model\n",
        "log_model2_accuracy    = accuracy_score(y_val, log_model2_val_preds)\n",
        "tree_model2_accuracy   = accuracy_score(y_val, tree_model2_val_preds)\n",
        "forest_model2_accuracy = accuracy_score(y_val, forest_model2_val_preds)\n",
        "svc_model2_accuracy    = accuracy_score(y_val, svc_model2_val_preds)\n",
        "xgb_model2_accuracy    = accuracy_score(y_val, xgb_model2_val_preds)\n",
        "\n",
        "# create brier scores for each model\n",
        "log_model2_mse    = mean_squared_error(y_val, log_model2_val_probas)\n",
        "tree_model2_mse   = mean_squared_error(y_val, tree_model2_val_probas)\n",
        "forest_model2_mse = mean_squared_error(y_val, forest_model2_val_probas)\n",
        "svc_model2_mse    = mean_squared_error(y_val, svc_model2_val_probas)\n",
        "xgb_model2_mse    = mean_squared_error(y_val, xgb_model2_val_probas)\n",
        "\n",
        "# create cross validation scores for each model\n",
        "log_model2_cv    = cross_val_score(log_model2, X_train_scaled, y_train, cv=10).mean()\n",
        "tree_model2_cv   = cross_val_score(tree_model2, X_train, y_train, cv=10).mean()\n",
        "forest_model2_cv = cross_val_score(forest_model2, X_train, y_train, cv=10).mean()\n",
        "svc_model2_cv    = cross_val_score(svc_model2, X_train_scaled, y_train, cv=10).mean()\n",
        "xgb_model2_cv    = cross_val_score(xgb_model2, X_train, y_train, cv=10).mean()\n",
        "\n",
        "# append to dataframe\n",
        "model2_success = pd.DataFrame({\n",
        "    'Model': ['Logistic Regression','Decision Tree','Random Forest','SVM','XGBoost'],\n",
        "    'Accuracy Score': [log_model2_accuracy, tree_model2_accuracy, forest_model2_accuracy, svc_model2_accuracy, xgb_model2_accuracy],\n",
        "    'MSE':            [log_model2_mse, tree_model2_mse, forest_model2_mse, svc_model2_mse, xgb_model2_mse],\n",
        "    'CV Score':       [log_model2_cv, tree_model2_cv, forest_model2_cv, svc_model2_cv, xgb_model2_cv],\n",
        "    'Model 2 - Model 1 Accuracy': [log_model2_accuracy - log_model_accuracy, tree_model2_accuracy - tree_model_accuracy, forest_model2_accuracy - forest_model_accuracy,svc_model2_accuracy - svc_model_accuracy, xgb_model2_accuracy - xgb_model_accuracy],\n",
        "    'Best Params':    [log_grid.best_params_, tree_grid.best_params_, forest_grid.best_params_, svc_grid.best_params_, xgb_grid.best_params_]\n",
        "})\n",
        "\n",
        "# output dataframe\n",
        "model2_success.sort_values(by='Accuracy Score', ascending=False).sort_values('MSE', ascending=True).reset_index(drop=True)"
      ]
    },
