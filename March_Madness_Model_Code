      "source": [
        "## Efficiency Metrics\n",
        "\n",
        "# Offensive Efficiency - 100 * (Points Scored/Total Possessions)\n",
        "games_seperated['Off_Eff'] = 100 * (games_seperated['Score']/games_seperated['Possessions'])\n",
        "games_seperated['Opp_Off_Eff'] = 100 * (games_seperated['OppScore']/games_seperated['Opp_Possessions'])\n",
        "\n",
        "# Defensive Efficiency\n",
        "games_seperated['Def_Eff'] = 100 * (games_seperated['OppScore']/games_seperated['Possessions'])\n",
        "games_seperated['Opp_Def_Eff'] = 100 * (games_seperated['Score']/games_seperated['Opp_Possessions'])\n",
        "\n",
        "# Net Efficiency\n",
        "games_seperated['Net_Eff'] = games_seperated['Off_Eff'] - games_seperated['Def_Eff']\n",
        "games_seperated['Opp_Net_Eff'] = games_seperated['Opp_Off_Eff'] - games_seperated['Opp_Def_Eff']"
      ]
    },
