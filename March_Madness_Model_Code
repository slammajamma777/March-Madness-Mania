      "source": [
        "## Define parameter grids for each model\n",
        "\n",
        "log_params = {\n",
        "    'C': [0.01, 0.1, 1, 10, 100],\n",
        "    'penalty': ['l1', 'l2'],\n",
        "    'solver': ['liblinear', 'saga']\n",
        "}\n",
        "\n",
        "tree_params = {\n",
        "    'max_depth': [3, 5, 7, 10, None],\n",
        "    'min_samples_split': [2, 5, 10],\n",
        "    'min_samples_leaf': [1, 2, 4],\n",
        "    'criterion': ['gini', 'entropy']\n",
        "}\n",
        "\n",
        "forest_params = {\n",
        "    'n_estimators': [50, 100, 200],\n",
        "    'max_depth': [3, 5, 7, 10, None],\n",
        "    'max_features': ['sqrt', 'log2'],\n",
        "    'min_samples_split': [2, 5, 10],\n",
        "    'min_samples_leaf': [1, 2, 4]\n",
        "}\n",
        "\n",
        "svc_params = {\n",
        "    'C': [0.01, 0.1, 1, 10, 100],\n",
        "    'kernel': ['linear', 'rbf'],\n",
        "    'gamma': ['scale', 'auto']\n",
        "}\n",
        "\n",
        "xgb_params = {\n",
        "    'n_estimators': [50, 100, 200],\n",
        "    'max_depth': [3, 5, 7],\n",
        "    'learning_rate': [0.01, 0.05, 0.1, 0.3],\n",
        "    'subsample': [0.6, 0.8, 1.0],\n",
        "    'colsample_bytree': [0.6, 0.8, 1.0],\n",
        "    'min_child_weight': [1, 3, 5]\n",
        "}\n",
        "\n",
        "## Run GridSearchCV for each model\n",
        "# using cv=5 for 5-fold cross validation\n",
        "# scoring on accuracy as primary metric\n",
        "\n",
        "log_grid = GridSearchCV(\n",
        "    LogisticRegression(random_state=42, max_iter=1000),\n",
        "    log_params, cv=5, scoring='accuracy', n_jobs=-1, verbose=1\n",
        ")\n",
        "\n",
        "tree_grid = GridSearchCV(\n",
        "    DecisionTreeClassifier(random_state=42),\n",
        "    tree_params, cv=5, scoring='accuracy', n_jobs=-1, verbose=1\n",
        ")\n",
        "\n",
        "forest_grid = GridSearchCV(\n",
        "    RandomForestClassifier(random_state=42),\n",
        "    forest_params, cv=5, scoring='accuracy', n_jobs=-1, verbose=1\n",
        ")\n",
        "\n",
        "svc_grid = GridSearchCV(\n",
        "    SVC(random_state=42, probability=True),\n",
        "    svc_params, cv=5, scoring='accuracy', n_jobs=-1, verbose=1\n",
        ")\n",
        "\n",
        "xgb_grid = GridSearchCV(\n",
        "    xgb.XGBClassifier(random_state=42, eval_metric='logloss'),\n",
        "    xgb_params, cv=5, scoring='accuracy', n_jobs=-1, verbose=1\n",
        ")\n",
        "\n",
        "## Fit all grids on training data\n",
        "print('Fitting Logistic Regression...')\n",
        "log_grid.fit(X_train_scaled, y_train)\n",
        "\n",
        "print('Fitting Decision Tree...')\n",
        "tree_grid.fit(X_train, y_train)\n",
        "\n",
        "print('Fitting Random Forest...')\n",
        "forest_grid.fit(X_train, y_train)\n",
        "\n",
        "print('Fitting SVM...')\n",
        "svc_grid.fit(X_train_scaled, y_train)\n",
        "\n",
        "print('Fitting XGBoost...')\n",
        "xgb_grid.fit(X_train, y_train)\n",
        "\n",
        "## Print best parameters for each model\n",
        "print('\\nBest Parameters:')\n",
        "print('Logistic Regression:', log_grid.best_params_)\n",
        "print('Decision Tree:',       tree_grid.best_params_)\n",
        "print('Random Forest:',       forest_grid.best_params_)\n",
        "print('SVM:',                 svc_grid.best_params_)\n",
        "print('XGBoost:',             xgb_grid.best_params_)\n",
        "\n",
        "## Evaluate best models on validation set\n",
        "best_models = {\n",
        "    'Logistic Regression': (log_grid.best_estimator_,   True),\n",
        "    'Decision Tree':        (tree_grid.best_estimator_,  False),\n",
        "    'Random Forest':        (forest_grid.best_estimator_,False),\n",
        "    'SVM':                  (svc_grid.best_estimator_,   True),\n",
        "    'XGBoost':              (xgb_grid.best_estimator_,   False)\n",
        "}\n",
        "\n",
        "tuned_results = []\n",
        "\n",
        "for name, (model, scaled) in best_models.items():\n",
        "    X_v = X_val_scaled if scaled else X_val\n",
        "\n",
        "    preds = model.predict(X_v)\n",
        "    probs = model.predict_proba(X_v)[:,1]\n",
        "\n",
        "    tuned_results.append({\n",
        "        'Model':         name,\n",
        "        'Best Params':   log_grid.best_params_ if name == 'Logistic Regression'\n",
        "                         else tree_grid.best_params_ if name == 'Decision Tree'\n",
        "                         else forest_grid.best_params_ if name == 'Random Forest'\n",
        "                         else svc_grid.best_params_ if name == 'SVM'\n",
        "                         else xgb_grid.best_params_,\n",
        "        'Val Accuracy':  round(accuracy_score(y_val, preds), 4),\n",
        "        'Val Brier':     round(brier_score_loss(y_val, probs), 4),\n",
        "        'Val AUC-ROC':   round(roc_auc_score(y_val, probs), 4),\n",
        "        'Val Log Loss':  round(log_loss(y_val, probs), 4)\n",
        "    })\n",
        "\n",
        "tuned_df = pd.DataFrame(tuned_results).set_index('Model')\n",
        "display(tuned_df)"
      ]
    },
